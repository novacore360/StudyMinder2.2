<?xml version="1.0" encoding="utf-8"?>
<resources>
    <style name="Theme.StudyMinder" parent="Theme.Material3.Light.NoActionBar">
        <item name="colorPrimary">@color/mocha_green</item>
        <item name="colorPrimaryVariant">@color/mocha_green_dark</item>
        <item name="colorOnPrimary">@color/white</item>
        <item name="colorSecondary">@color/mocha_brown</item>
        <item name="colorOnSecondary">@color/white</item>
        <item name="colorSurface">@color/mocha_warm_white</item>
        <item name="colorOnSurface">@color/text_primary</item>
        <item name="android:windowBackground">@color/mocha_warm_white</item>
        <item name="android:statusBarColor">@color/mocha_green_dark</item>
        <item name="android:navigationBarColor">@color/white</item>
        <item name="materialButtonStyle">@style/MochaButton</item>
        <item name="editTextStyle">@style/MochaEditText</item>
    </style>

    <style name="Theme.StudyMinder.Splash" parent="Theme.SplashScreen">
        <item name="windowSplashScreenBackground">@color/mocha_green_dark</item>
        <item name="windowSplashScreenAnimatedIcon">@drawable/ic_splash_logo</item>
        <item name="postSplashScreenTheme">@style/Theme.StudyMinder</item>
    </style>

    <style name="MochaButton" parent="Widget.Material3.Button">
        <item name="backgroundTint">@color/mocha_green</item>
        <item name="cornerRadius">12dp</item>
        <item name="android:textColor">@color/white</item>
        <item name="android:letterSpacing">0.02</item>
    </style>

    <style name="MochaButton.Outline" parent="Widget.Material3.Button.OutlinedButton">
        <item name="strokeColor">@color/mocha_green</item>
        <item name="cornerRadius">12dp</item>
        <item name="android:textColor">@color/mocha_green</item>
    </style>

    <style name="MochaEditText" parent="Widget.Material3.TextInputEditText.OutlinedBox">
        <item name="android:textColor">@color/text_primary</item>
        <item name="android:textColorHint">@color/text_hint</item>
    </style>

    <style name="MochaTextInputLayout" parent="Widget.Material3.TextInputLayout.OutlinedBox">
        <item name="boxStrokeColor">@color/mocha_green</item>
        <item name="hintTextColor">@color/mocha_green</item>
        <item name="boxCornerRadiusTopStart">12dp</item>
        <item name="boxCornerRadiusTopEnd">12dp</item>
        <item name="boxCornerRadiusBottomStart">12dp</item>
        <item name="boxCornerRadiusBottomEnd">12dp</item>
    </style>

    <style name="BottomSheetStyle" parent="Theme.Material3.Light.BottomSheetDialog">
        <item name="bottomSheetStyle">@style/MochaBottomSheet</item>
    </style>

    <style name="MochaBottomSheet" parent="Widget.Material3.BottomSheet.Modal">
        <item name="shapeAppearance">@style/MochaBottomSheetShape</item>
        <item name="android:background">@color/mocha_warm_white</item>
    </style>

    <style name="MochaBottomSheetShape" parent="">
        <item name="cornerFamily">rounded</item>
        <item name="cornerSizeTopLeft">24dp</item>
        <item name="cornerSizeTopRight">24dp</item>
        <item name="cornerSizeBottomLeft">0dp</item>
        <item name="cornerSizeBottomRight">0dp</item>
    </style>

    <style name="DatePickerStyle" parent="Theme.Material3.Light.Dialog">
        <item name="colorPrimary">@color/mocha_green</item>
        <item name="colorOnPrimary">@color/white</item>
        <!-- Make Cancel / OK buttons visible (mocha green text on white dialog) -->
        <item name="buttonBarPositiveButtonStyle">@style/MochaDialogButton</item>
        <item name="buttonBarNegativeButtonStyle">@style/MochaDialogButton</item>
        <item name="android:buttonBarPositiveButtonStyle">@style/MochaDialogButton</item>
        <item name="android:buttonBarNegativeButtonStyle">@style/MochaDialogButton</item>
    </style>

    <style name="TimePickerStyle" parent="Theme.Material3.Light.Dialog">
        <item name="colorPrimary">@color/mocha_green</item>
        <item name="colorOnPrimary">@color/white</item>
        <!-- Make Cancel / OK buttons visible (mocha green text on white dialog) -->
        <item name="buttonBarPositiveButtonStyle">@style/MochaDialogButton</item>
        <item name="buttonBarNegativeButtonStyle">@style/MochaDialogButton</item>
        <item name="android:buttonBarPositiveButtonStyle">@style/MochaDialogButton</item>
        <item name="android:buttonBarNegativeButtonStyle">@style/MochaDialogButton</item>
    </style>

    <style name="MochaDialogButton" parent="Widget.Material3.Button.TextButton.Dialog">
        <item name="android:textColor">@color/mocha_green</item>
        <item name="rippleColor">@color/mocha_green_tint</item>
    </style>

    <style name="SectionHeader" parent="TextAppearance.Material3.TitleMedium">
        <item name="android:textColor">@color/mocha_green_dark</item>
        <item name="android:fontFamily">sans-serif-medium</item>
        <item name="android:letterSpacing">0.02</item>
    </style>
</resources>
