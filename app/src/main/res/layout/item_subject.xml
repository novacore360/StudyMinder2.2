<?xml version="1.0" encoding="utf-8"?>
<androidx.cardview.widget.CardView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginBottom="12dp"
    app:cardCornerRadius="16dp"
    app:cardElevation="3dp"
    app:cardBackgroundColor="@color/mocha_card">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:padding="16dp"
        android:gravity="center_vertical">

        <!-- Avatar circle -->
        <LinearLayout
            android:id="@+id/avatarCircle"
            android:layout_width="52dp"
            android:layout_height="52dp"
            android:background="@drawable/bg_avatar_circle"
            android:gravity="center"
            android:layout_marginEnd="14dp">
            <TextView
                android:id="@+id/tvInitial"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="C"
                android:textSize="22sp"
                android:textColor="@color/white"
                android:fontFamily="sans-serif-medium" />
        </LinearLayout>

        <!-- Info -->
        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:orientation="vertical">

            <TextView
                android:id="@+id/tvSubjectName"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Calculus II"
                android:textSize="16sp"
                android:textColor="@color/text_primary"
                android:fontFamily="sans-serif-medium"
                android:maxLines="1"
                android:ellipsize="end" />

            <TextView
                android:id="@+id/tvSubjectId"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="MATH201"
                android:textSize="11sp"
                android:textColor="@color/mocha_green"
                android:background="@drawable/bg_chip"
                android:paddingStart="8dp"
                android:paddingEnd="8dp"
                android:paddingTop="2dp"
                android:paddingBottom="2dp"
                android:layout_marginTop="4dp" />

            <TextView
                android:id="@+id/tvProfessor"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="👨‍🏫 Dr. Smith"
                android:textSize="12sp"
                android:textColor="@color/text_secondary"
                android:layout_marginTop="6dp" />

            <TextView
                android:id="@+id/tvRoom"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="🏫 Room 204"
                android:textSize="12sp"
                android:textColor="@color/text_secondary"
                android:layout_marginTop="2dp" />
        </LinearLayout>

        <!-- Actions -->
        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:orientation="vertical">

            <ImageButton
                android:id="@+id/btnEdit"
                android:layout_width="36dp"
                android:layout_height="36dp"
                android:src="@drawable/ic_edit"
                android:background="@android:color/transparent"
                app:tint="@color/mocha_green"
                android:contentDescription="Edit" />

            <ImageButton
                android:id="@+id/btnDelete"
                android:layout_width="36dp"
                android:layout_height="36dp"
                android:src="@drawable/ic_delete"
                android:background="@android:color/transparent"
                app:tint="@color/status_missed"
                android:layout_marginTop="4dp"
                android:contentDescription="Delete" />
        </LinearLayout>

    </LinearLayout>
</androidx.cardview.widget.CardView>
