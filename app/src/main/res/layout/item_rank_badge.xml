<?xml version="1.0" encoding="utf-8"?>
<!-- Root is a FrameLayout so the card can be scaled/translated by the
     PageTransformer without clipping the overflow badge -->
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:clipChildren="false"
    android:clipToPadding="false"
    android:paddingBottom="16dp">

    <com.google.android.material.card.MaterialCardView
        android:id="@+id/cardBadge"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:layout_marginHorizontal="8dp"
        app:cardCornerRadius="20dp"
        app:cardElevation="8dp"
        app:cardBackgroundColor="@color/mocha_card">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:orientation="vertical"
            android:gravity="center"
            android:paddingTop="24dp"
            android:paddingBottom="20dp"
            android:paddingHorizontal="12dp">

            <!-- Badge container — overflow allowed for Sovereign+ -->
            <FrameLayout
                android:id="@+id/badgeContainer"
                android:layout_width="160dp"
                android:layout_height="160dp"
                android:clipChildren="false"
                android:clipToPadding="false">

                <ImageView
                    android:id="@+id/ivBadge"
                    android:layout_width="160dp"
                    android:layout_height="160dp"
                    android:layout_gravity="center"
                    android:scaleType="fitCenter"
                    android:adjustViewBounds="true" />

                <!-- Shine sweep -->
                <View
                    android:id="@+id/viewShine"
                    android:layout_width="40dp"
                    android:layout_height="160dp"
                    android:background="@drawable/shine_sweep"
                    android:layout_gravity="center" />

                <!-- Lock overlay -->
                <View
                    android:id="@+id/viewLockedOverlay"
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:background="#80000000"
                    android:visibility="gone" />

                <ImageView
                    android:id="@+id/ivLockIcon"
                    android:layout_width="40dp"
                    android:layout_height="40dp"
                    android:layout_gravity="center"
                    android:src="@drawable/ic_lock"
                    android:visibility="gone" />

            </FrameLayout>

            <!-- CURRENT dot + label -->
            <View
                android:id="@+id/currentIndicator"
                android:layout_width="8dp"
                android:layout_height="8dp"
                android:background="@drawable/dot_current_rank"
                android:layout_marginTop="10dp"
                android:visibility="gone" />

            <TextView
                android:id="@+id/tvCurrentLabel"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="CURRENT"
                android:textSize="9sp"
                android:textColor="@color/rank_gold"
                android:textStyle="bold"
                android:letterSpacing="0.12"
                android:visibility="gone" />

            <TextView
                android:id="@+id/tvBadgeName"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:textSize="18sp"
                android:textColor="@color/text_primary"
                android:textStyle="bold"
                android:gravity="center"
                android:layout_marginTop="8dp" />

            <TextView
                android:id="@+id/tvBadgeQuote"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:textSize="11sp"
                android:textColor="@color/text_secondary"
                android:textStyle="italic"
                android:gravity="center"
                android:maxLines="3"
                android:ellipsize="end"
                android:layout_marginTop="6dp" />

            <TextView
                android:id="@+id/tvBadgePoints"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:textSize="12sp"
                android:textColor="@color/rank_gold"
                android:textStyle="bold"
                android:layout_marginTop="6dp" />

        </LinearLayout>
    </com.google.android.material.card.MaterialCardView>

</FrameLayout>
