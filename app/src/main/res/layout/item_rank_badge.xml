<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:padding="6dp"
    android:gravity="center">

    <!-- Outer card -->
    <com.google.android.material.card.MaterialCardView
        android:id="@+id/cardBadge"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        app:cardCornerRadius="12dp"
        app:cardElevation="4dp"
        app:cardBackgroundColor="@color/mocha_card">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:gravity="center"
            android:padding="8dp">

            <!-- Badge container (allows overflow for large badges) -->
            <FrameLayout
                android:id="@+id/badgeContainer"
                android:layout_width="80dp"
                android:layout_height="80dp"
                android:clipChildren="false"
                android:clipToPadding="false">

                <ImageView
                    android:id="@+id/ivBadge"
                    android:layout_width="80dp"
                    android:layout_height="80dp"
                    android:layout_gravity="center"
                    android:scaleType="fitCenter"
                    android:adjustViewBounds="true" />

                <!-- Shine sweep overlay -->
                <View
                    android:id="@+id/viewShine"
                    android:layout_width="20dp"
                    android:layout_height="80dp"
                    android:background="@drawable/shine_sweep"
                    android:layout_gravity="center" />

                <!-- Lock overlay -->
                <View
                    android:id="@+id/viewLockedOverlay"
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:background="#80000000"
                    android:visibility="gone" />

                <ImageView
                    android:id="@+id/ivLockIcon"
                    android:layout_width="28dp"
                    android:layout_height="28dp"
                    android:layout_gravity="center"
                    android:src="@drawable/ic_lock"
                    android:visibility="gone" />

            </FrameLayout>

            <!-- Current rank indicator dot -->
            <View
                android:id="@+id/currentIndicator"
                android:layout_width="8dp"
                android:layout_height="8dp"
                android:background="@drawable/dot_current_rank"
                android:layout_marginTop="4dp"
                android:visibility="gone" />

            <TextView
                android:id="@+id/tvCurrentLabel"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="CURRENT"
                android:textSize="8sp"
                android:textColor="@color/rank_gold"
                android:textStyle="bold"
                android:letterSpacing="0.1"
                android:visibility="gone" />

            <TextView
                android:id="@+id/tvBadgeName"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:textSize="11sp"
                android:textColor="@color/text_primary"
                android:textStyle="bold"
                android:gravity="center"
                android:maxLines="1"
                android:ellipsize="end"
                android:layout_marginTop="4dp" />

            <TextView
                android:id="@+id/tvBadgePoints"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:textSize="9sp"
                android:textColor="@color/text_secondary" />

        </LinearLayout>
    </com.google.android.material.card.MaterialCardView>

</LinearLayout>
